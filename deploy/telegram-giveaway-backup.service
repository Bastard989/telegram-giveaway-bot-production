[Unit]
Description=Backup Telegram Giveaway Bot SQLite database
After=telegram-giveaway-bot.service

[Service]
Type=oneshot
User=giveawaybot
Group=giveawaybot
WorkingDirectory=/opt/telegram-giveaway-bot
Environment=BACKUP_RETENTION_DAYS=14
ExecStart=/opt/telegram-giveaway-bot/.venv/bin/python /opt/telegram-giveaway-bot/scripts/server_backup.py
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/telegram-giveaway-bot/runtime
